# Deployment used by `npx convex dev`
# → Run `npx convex dev` and select/create a project. This value is auto-generated in .env.local.
CONVEX_DEPLOYMENT=

# ─── Convex backend URLS ────────────────────────────────────────────────────
# → Found in the Convex dashboard (https://dashboard.convex.dev) under your project's "Settings" → "URL & Deploy Key".
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# ─── FareNexus API (UAT Credentials) ────────────────────────────────────────
# → Obtain from FareNexus by signing up at https://www.farenexushub.com or contacting their sales team.
# → FARENEXUS_BASE_URL: UAT = https://a.uat.w.farenexushub.com | Production = provided by FareNexus.
# → FARENEXUS_CLIENT_ID, FARENEXUS_AGENCY_KEY, FARENEXUS_TRAVEL_AGENCY_ID: Assigned by FareNexus upon registration.
# → FARENEXUS_API_SOURCE: The GDS source (e.g. SABRE, AMADEUS). Confirm with FareNexus which source is provisioned for your account.
FARENEXUS_BASE_URL=
FARENEXUS_CLIENT_ID=
FARENEXUS_AGENCY_KEY=
FARENEXUS_API_SOURCE=
FARENEXUS_TRAVEL_AGENCY_ID=

# ─── Sabre API (CERT sandbox) ───────────────────────────────────────────────
# → Register at https://developer.sabre.com to get sandbox (CERT) credentials.
# → SABRE_USER_ID & SABRE_PASSWORD: Found in the Sabre Dev Studio portal under "My Account" → "Credentials".
# → SABRE_BASE_URL: CERT = https://api.cert.platform.sabre.com | Production = https://api.platform.sabre.com
SABRE_USER_ID=
SABRE_PASSWORD=
SABRE_BASE_URL=

# ─── LiteAPI (sandbox) ──────────────────────────────────────────────────────
# → Sign up at https://www.liteapi.travel and generate an API key from the dashboard.
# → Sandbox keys are prefixed with "sand_", production keys with "prod_".
LITEAPI_KEY=
